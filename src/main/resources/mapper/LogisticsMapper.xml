<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!-- 物流 logistics：按订单号关联 -->
<mapper namespace="com.reservation.teaecommerceplatform.mapper.LogisticsMapper">
    
    <resultMap id="BaseResultMap" type="com.reservation.teaecommerceplatform.entity.Logistics">
        <id column="id" property="id"/>
        <result column="order_id" property="orderId"/>
        <result column="logistics_no" property="logisticsNo"/>
        <result column="company" property="company"/>
        <result column="status" property="status"/>
        <result column="detail" property="detail"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectByOrderId" resultMap="BaseResultMap">
        SELECT * FROM logistics WHERE order_id = #{orderId}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO logistics (order_id, logistics_no, company, status, detail, create_time, update_time)
        VALUES (#{orderId}, #{logisticsNo}, #{company}, #{status}, #{detail}, NOW(), NOW())
    </insert>

    <update id="update">
        UPDATE logistics
        <set>
            <if test="logisticsNo != null">logistics_no = #{logisticsNo},</if>
            <if test="company != null">company = #{company},</if>
            <if test="status != null">status = #{status},</if>
            <if test="detail != null">detail = #{detail},</if>
            update_time = NOW()
        </set>
        WHERE id = #{id}
    </update>

</mapper>

