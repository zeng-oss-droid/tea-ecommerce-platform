<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!-- 购物车表 cart -->
<mapper namespace="com.reservation.teaecommerceplatform.mapper.CartMapper">
    
    <resultMap id="BaseResultMap" type="com.reservation.teaecommerceplatform.entity.Cart">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="product_id" property="productId"/>
        <result column="quantity" property="quantity"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM cart WHERE id = #{id}
    </select>

    <select id="selectByUserIdAndProductId" resultMap="BaseResultMap">
        SELECT * FROM cart WHERE user_id = #{userId} AND product_id = #{productId}
    </select>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT * FROM cart WHERE user_id = #{userId} ORDER BY create_time DESC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO cart (user_id, product_id, quantity, create_time, update_time)
        VALUES (#{userId}, #{productId}, #{quantity}, NOW(), NOW())
    </insert>

    <update id="update">
        UPDATE cart SET quantity = #{quantity}, update_time = NOW() WHERE id = #{id}
    </update>

    <update id="updateQuantity">
        UPDATE cart SET quantity = #{quantity}, update_time = NOW() WHERE id = #{id}
    </update>

    <delete id="delete">
        DELETE FROM cart WHERE id = #{id}
    </delete>

    <delete id="deleteByUserId">
        DELETE FROM cart WHERE user_id = #{userId}
    </delete>

</mapper>

